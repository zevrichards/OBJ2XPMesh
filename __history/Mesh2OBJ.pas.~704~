procedure TForm1.Drag_Drop_File(var Msg: TMessage);
//code from http://swepc.se/blog/how-to-drag-drop-files-delphi-10/
var
  extension: string;
  limit, number: Integer;
  path: array [0 .. MAX_COMPUTERNAME_LENGTH + MAX_PATH] of Char;
begin
  limit := DragQueryFile(Msg.WParam, $FFFFFFFF, path, 275) - 1;
  {
    if the index value is 0xFFFFFFFF,
    the return value is a count of the dropped files.
  }
  for number := 0 to limit do
  begin
    DragQueryFile(Msg.WParam, number, path, 275);
    {
      if the index value is between zero and the total number of dropped files,
      the return value is the required size, in characters.
    }
    if (FileExists(path)) then
    begin
      extension := ExtractFileExt(path);
      // Extracts the extension part of path like [.jpg, .png, .txt]
      if (extension = '.txt') then
      begin
        TXTCombo.Text := path;
        DSFCombo.Text := '';
        OutputDirCombo.text := ExtractFilePath(path);
        OutputNameCombo.Text := ChangeFileExt(ExtractFileName(path), '')+'.dsf';
      end
      else if (extension = '.dsf') then
      begin
        DSFCombo.Text := path;
        TXTCombo.Text := '';
        OutputDirCombo.text := ExtractFilePath(path);
        OutputNameCombo.Text := ChangeFileExt(ExtractFileName(path), '')+'.txt';
      end
      else
      begin
        MessageBox(Form1.Handle, PChar('Not a DSF or TXT file.'),
          PChar('DSF Tool'), MB_ICONWARNING);
      end;

    end;

  end;
  DragFinish(Msg.WParam);
  // This frees the resources used to store information about the drop.

  If RunDSFToolCheckBox.Checked then
    DSFToolButton.Click;

end;


procedure TForm1.RemoveDuplicateFaces;

var
  aGroup: TOBJ_Group;
  aFace: TOBJ_Face;
  aFR, anotherFR: myFaceRecord;
  FaceList: array of myFaceRecord;
  i, f, dups: integer;


begin
  /// Create list/array of all vertices in OBJ as records
  /// Iterate through array, checking to see if each other record which is not of the same group and is not already a duplicate has verts spatially equal to this one.
  /// When complete, remove all duplicate faces from groups by Face ID

  // Create list/array of all vertices in OBJ as records
  SetLength(FaceList, 0);
  dups:=0;
  Memo1.Lines.Add('Removing duplicate faces...');
  for aGroup in anOBJ.children do
    begin
      for aFace in aGroup.faces do
      begin
        With aFR do
        begin
          Group := aGroup.id;
          Face := aFace.id;
          v1 := aGroup.FindVertex(aFace.v1);
          v2 := aGroup.FindVertex(aFace.v2);
          v3 := aGroup.FindVertex(aFace.v3);
          isDuplicate := false;
        end;
        SetLength(FaceList, length(FaceList)+1);
        FaceList[length(FaceList)-1] := aFR;
      end;
    end;
    Memo1.Lines.Add('Found '+IntToStr(length(FaceList))+' total faces...');
    Memo1.Lines.Add('Searching for duplicates...');

    ProgressBar1.Max := length(FaceList);
    ProgressBar1.Position := 0;

    // Iterate through array, checking to see if each other record which is not of the same group and is not already a duplicate has verts spatially equal to this one.
    for i := 0 to high(FaceList) do
    begin
      ProgressBar1.Position := ProgressBar1.Position +1;
      for f := 0 to high(FaceList) do
      begin
//        ProgressBar1.Position := Trunc(((i*f)/(length(FaceList)*length(FaceList)))*100);
        if FaceList[i].Face<>FaceList[f].Face then  //make sure we are not comparing a face to itself
        begin
          if not FaceList[i].isDuplicate then   //make sure we don't already know that this is a duplicate
          begin
            if (FaceList[i].Group <> FaceList[f].Group) and (FaceList[f].isDuplicate = false) then   //make sure that the faces are not in the same group and that the other face is not already known to be a duplicate
            begin
              if CompareFaces(FaceList[i], FaceList[f]) then  //compare the verts of the faces
              begin
                FaceList[f].isDuplicate := true;
                inc(dups);
              end;
            end;
          end;
        end;
      end;
    end;
    Memo1.Lines.Add('Found '+IntToStr(dups)+' duplicate faces...');

    //remove non-duplicates from list.
    {for i := high(FaceList) downto 0 do
      begin
        if not FaceList[i].isDuplicate then
          FaceList[i] := nil;
      end;  }

    // When complete, remove all duplicate faces from groups by Face ID
    for aFR in FaceList do
    begin
      if aFR.isDuplicate then
      begin
        for aGroup in anOBJ.children do
          begin
            if aGroup.id = aFR.Group then
            begin
              for aFace in aGroup.Faces do
                begin
                  if aFR.Face = aFace.id then
                  begin
                    aGroup.Faces.Remove(aFace);
                    break;
                  end;
                end;
            end;
          end;
      end;
    end;
    Memo1.Lines.Add('Finished removing duplicate faces.');

end;

function TForm1.CompareFaces(aFaceRecord, anotherFaceRecord: myFaceRecord): boolean;
begin
  result := false;
  if (CompareVerts(aFaceRecord.v1, anotherFaceRecord.v1)) or (CompareVerts(aFaceRecord.v1, anotherFaceRecord.v2)) or (CompareVerts(aFaceRecord.v1, anotherFaceRecord.v3)) then
  begin
    if (CompareVerts(aFaceRecord.v2, anotherFaceRecord.v1)) or (CompareVerts(aFaceRecord.v2, anotherFaceRecord.v2)) or (CompareVerts(aFaceRecord.v2, anotherFaceRecord.v3)) then
    begin
      if (CompareVerts(aFaceRecord.v3, anotherFaceRecord.v1)) or (CompareVerts(aFaceRecord.v3, anotherFaceRecord.v2)) or (CompareVerts(aFaceRecord.v3, anotherFaceRecord.v3)) then
        result := true;
    end;
  end;
end;

function TForm1.CompareVerts(aVertex, AnotherVertex: TVERTEX): boolean;
begin
  result := false;
  if (aVertex.long=anotherVertex.long) and (aVertex.lat=anotherVertex.lat) and (aVertex.height=anotherVertex.height) then
    result := true;
end;

