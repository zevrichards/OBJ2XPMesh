procedure TForm1.Triangles(prim_id: integer);
var aVertex: TVERTEX;
    x,y: integer;
begin
//   OBJ_Vertex_list.Clear;
//   OBJ_Face_List.clear; //clear list to start over

   If Land_Vertex_list.Count <> 0 then
    x := Land_Vertex_list.Count
   else
    x:= 0;

   If Sea_Vertex_list.Count <> 0 then
    y := Sea_Vertex_list.Count
   else
    y:= 0;
   //iterate through all patch_vertices which have a parent_id matching prim_id
   //store in vertex_list
   //create faces from groups of 3 and add to face list  ??

   //iterate through all patch_vertices which have a parent_id matching prim_id
   For aVertex in Land_VertexList do
   begin
     If aVertex.primitive_id = prim_id then
     begin
        //store in vertex_list
      Land_Vertex_list.Add(aVertex);
     end;
   end;

   For aVertex in Sea_VertexList do
   begin
     If aVertex.primitive_id = prim_id then
     begin
        //store in vertex_list
      Sea_Vertex_list.Add(aVertex);
     end;
   end;

   While x < Land_Vertex_list.Count do
   begin
    //create faces from groups of 3 and add to face list
    OBJ_Face_List.Add(TOBJ_Face.create(x+3, x+2, x+1, 'Land'));
    inc(x,3);
   end;

   While y < Sea_Vertex_list.Count do
   begin
    //create faces from groups of 3 and add to face list
    OBJ_Face_List.Add(TOBJ_Face.create(y+3, y+2, y+1, 'Sea'));
    inc(y,3);
   end;


end;

