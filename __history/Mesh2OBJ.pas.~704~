var FS: TFileStream;
    r,c, new_Value: integer;
    d: word;
    invalid_data: TList<Tinvalid>;
    value: Tinvalid;

begin


  FS:= TFileStream.Create(FileName, fmopenread + fmShareDenyNone{ or fmShareDenyWrite});
  rows_out := trunc(sqrt(FS.Size/8)*2);  //total_rows=total_columns
  progressbar1.Max := rows_out;
  progressbar1.Position := 0;
  invalid_data := TList<Tinvalid>.create;

  try
    FS.Position:=0;
    SetLength(RAW_Array, rows_out+1, rows_out+1);

    For r := rows_out downto 1 do
    begin
      progressbar1.Position := progressbar1.Position + 1;
      For c := 1 to rows_out do
      begin
        If FS.Read(d, sizeof(d)) > 0 then
        begin
          RAW_Array[r,c] := d;
          if (d > upper) or (d < lower) then
          begin
            Value.indices[0] := r;
            value.indices[1] := c;
            invalid_data.Add(Value);
          end;

        end;
      end;
    end;

  finally
    FS.Free;

  end;

  If interpolate then
  begin
    progressbar1.Position := 0;
    progressbar1.max := invalid_data.Count;
    For value in invalid_data do
    begin
      new_value := 0;
      r := value.indices[0];
      c := value.indices[1];

      If (RAW_Array[r-1,c] < upper) and (RAW_Array[r-1,c] > lower) then
        new_value := new_value+RAW_Array[r-1,c];
      If (RAW_Array[r+1,c] < upper) and (RAW_Array[r+1,c] > lower) then
        new_value := new_value+RAW_Array[r+1,c];
      If (RAW_Array[r,c-1] < upper) and (RAW_Array[r,c-1] > lower) then
        new_value := new_value+RAW_Array[r,c-1];
      If (RAW_Array[r,c+1] < upper) and (RAW_Array[r,c+1] > lower) then
        new_value := new_value+RAW_Array[r,c+1];
      new_value := new_Value div 4;

      Raw_Array[r,c] := new_value;
      progressbar1.Position := progressbar1.Position + 1;;
    end;
  end;

  invalid_data.Free;
end;

function TForm1.FindElevation(aVertex: TVertex; total_rows: integer): word;
var r,c: integer;
begin
//    Find XY position as fraction of extents
//    Determine row and column position based on fraction of total rows/columns

  //X and Y below may have been incorrectly exchanged
  r := trunc(((Extents[1]-(aVertex.lat))/(Extents[1]-Extents[2]))*total_rows);      //(N - vertex_lat)/(N-S) * total_rows
  c := trunc(((Extents[3]-(aVertex.long))/(Extents[3]-Extents[4]))*total_rows);    //(W - vertex_long)/(W-E) * total_columns

  result := RAW_array[r,c];
end;

procedure TForm1.SetExtents(aVertex: TVERTEX);
begin
    //northern most vertex
  If aVertex.lat > Extents[1] then
    Extents[1] := aVertex.lat;
  //southern most vertex
  If aVertex.lat < Extents[2] then
    Extents[2] := aVertex.lat;
  //western most vertex
  If aVertex.long < Extents[3] then
    Extents[3] := aVertex.long;
  //eastern most vertex
  If aVertex.long > Extents[4] then
    Extents[4] := aVertex.long;
end;

procedure TForm1.CombinePatches;
var aPatch, aNewPatch: TPATCH;
    aNewDSF: TDSF;
    ter_def, i: integer;
    aPrimitive: TPRIMITIVE;
    aVertex: TVERTEX;

begin

//  sort patches by terrain definition
//  create new DSF
//  get ter_def of first patch, create first new patch
//  iterate list comparing ter_def
//  add primitves of next patch to newDSF first patch,
//  continue unti next patch ter_def does not match ter_def of new first Pathc, then create new patch
//  repeat until end of aDSF.children
//  assign new DSF to old DSF

  ter_def := -1;

  aDSF.children.Sort(TComparer<TPATCH>.Construct(
  function (const L,R: TPATCH): integer
  begin
    result := CompareInt(L.ter_def, R.ter_def);
  end
  ));

  aNewDSF := TDSF.create;
  aNewDSF.children := TObjectList<TPATCH>.create;

//  for i := 0 to aDSF.children.count-1 do
  for aPatch in aDSF.children do
    begin
//      aPatch := aDSF.children[i];
      if aPatch.ter_def <> ter_def then
      begin
        ter_def := aPATCH.ter_def;
        aNewPatch := TPATCH.create('BEGIN_PATCH '+IntToStr(ter_def)+' 0.000000 -1.000000 1 7');
        aNewPatch.children.AddRange(aPatch.children);
        aNewDSF.children.add(aNewPatch);
      end
      else
        aNewPatch.children.addrange(aPatch.children);
    end;

  //sort Patches
  aNewDSF.children.Sort(TComparer<TPATCH>.Construct(
  function (const L,R: TPATCH): integer
  begin
    result := CompareInt(L.id, R.id);
  end
  ));

  for aPatch in aNewDSF.children do
    begin
      //sort primitives inside patches first
      aPatch.children.Sort(TComparer<TPRIMITIVE>.Construct(
      function (const L,R: TPRIMITIVE): integer
      begin
        result := CompareInt(L.id, R.id);
      end
      ));
      //then vertices inside primitives
      for aPrimitive in aPatch.children do
        begin
          aPrimitive.children.Sort(TComparer<TVERTEX>.Construct(
          function (const L,R: TVERTEX): integer
          begin
            result := CompareInt(L.id, R.id);
          end
          ));
        end;
    end;

  aDSF := aNewDSF;

end;

procedure TForm1.ResetVertReferences(operation: integer; myOBJ: TOBJ; out face_count: integer);
var aGroup: TOBJ_Group;
    aFace: TOBJ_Face;
    aVertex: TVERTEX;
    cum_vert_count: integer;
begin

  face_count:=0;
  cum_vert_count := 0;
  for aGroup in myOBJ.children do
  begin
    for aVertex in aGroup.Vertices do
      aVertex.id := aVertex.id + (cum_vert_count*operation);

    for aFace in aGroup.Faces do
    begin
      aFace.v1 := aFace.v1 + (cum_vert_count*operation);
      aFace.v2 := aFace.v2 + (cum_vert_count*operation);
      aFace.v3 := aFace.v3 + (cum_vert_count*operation);

      inc(face_count);
    end;
    cum_vert_count := cum_vert_count+aGroup.Vertices.Count;

  end;

end;

procedure TForm1.AddDetail;
var aGroup, anotherGroup: TOBJ_Group;
    aFace, anotherFace: TOBJ_Face;
    aVertex: TVERTEX;
    Face1, Face2, Face3, Face4: TOBJ_Face;
    Vert1, Vert2, Vert3, Vert4, Vert5, Vert6 : TVERTEX;
    aDetailedOBJ: TOBJ;
    NewVerts : TOBJ_Group;
    num_verts, new_face_count, original_face_count, original_Vert_count: integer;
begin

//  progressbar1.Max := 100;
  progressbar1.Position := 0;
  /// iterate through Groups
  ///If group is not sea
  /// For each face in group
  /// Create 4 new faces in place
  ///  New verts are halfway in between old verts
  ///  New faces are 1,4,6 4,2,5 6,5,3 & 4,5,6
  ///  Create new Group with new faces
  ///  add to new OBJ
  ///  add groups which were not changed
  ///  old OBJ := new OBJ
  ///
  original_Vert_count := vert_count;
//  vert_count := 0;

  aDetailedOBJ := TOBJ.create;

  Memo1.Lines.add('Creating new vertices and faces...');

//Decrement each ID in each group by the total number of verts before it
//We will be resetting each vertex and face reference to start at 1 for each group
  ResetVertReferences(-1, anOBJ, original_face_count);

//  Now we start adding detail, splitting each face into 4 smaller faces.
  try
    progressbar1.max := anOBJ.children.Count;
    for aGroup in anOBJ.children do
    begin
        NewVerts := TOBJ_Group.create('g Mesh0 0 temp');
//      if aGroup.ter_def <>  '0' then
//      begin
        anotherGroup := TOBJ_Group.Create('g Mesh0 0 anotherGroup');
        anotherGroup.ter_def := aGroup.ter_def;
        anotherGroup.Vertices := aGroup.Vertices;              //new vertices will be added to originals

        num_verts := aGroup.Vertices.Count+1;                     //all new vertex IDS will now start from this number
        for aFace in aGroup.Faces do
        begin
          Vert1 := aGroup.FindVertex(aFace.v1);
          Vert2 := aGroup.FindVertex(aFace.v2);
          Vert3 := aGroup.FindVertex(aFace.v3);

          Vert4 := TVERTEX.create(Vert1, Vert2, num_verts);
          if NewVerts.FindVertex(Vert4) = nil then   //check to see whether a vertex already exists at identical position
          begin
            NewVerts.vertices.add(Vert4);                      //if not, add it to the new list
            inc(num_verts);
            anotherGroup.vertices.add(Vert4);                  //and add it to the Group
          end
          else
          begin
            Vert4 := NewVerts.FindVertex(Vert4);     //else replace it with the one we found so that there are no duplicates
//              dec(num_verts);                         //ignore the last created vertice
          end;

          Vert5 := TVERTEX.create(Vert2, Vert3, num_verts);
          if NewVerts.FindVertex(Vert5) = nil then   //check to see whether vert exists at identical position
          begin
            NewVerts.vertices.add(Vert5);                      //if not, add it to the new list
            inc(num_verts);
            anotherGroup.vertices.add(Vert5);
          end
          else
          begin
            Vert5 := NewVerts.FindVertex(Vert5);     //else replace it with the one we found so that there are no duplicates
//              dec(num_verts);                         //ignore the last created vertice
          end;

          Vert6 := TVERTEX.create(Vert3, Vert1, num_verts);
          if NewVerts.FindVertex(Vert6) = nil then   //check to see whether vert exists at identical position
          begin
            NewVerts.vertices.add(Vert6);                      //if not, add it to the new list
            inc(num_verts);
            anotherGroup.vertices.add(Vert6);
          end
          else
          begin
            Vert6 := NewVerts.FindVertex(Vert6);     //else replace it with the one we found so that there are no duplicates
//              dec(num_verts);                         //ignore the last created vertice
          end;

          Face1 := TOBJ_Face.Create(Vert1.id, Vert4.id, Vert6.id, aGroup.ter_def);
          Face2 := TOBJ_Face.Create(Vert4.id, Vert2.id, Vert5.id, aGroup.ter_def);
          Face3 := TOBJ_Face.Create(Vert6.id, Vert5.id, Vert3.id, aGroup.ter_def);
          Face4 := TOBJ_Face.Create(Vert4.id, Vert5.id, Vert6.id, aGroup.ter_def);


          anotherGroup.faces.addrange([Face1, Face2, Face3, Face4]);    //faces are replaced completely
        end;

        aDetailedOBJ.children.Add(anotherGroup);

//      end;
      progressbar1.Position := progressbar1.Position + 1;
      NewVerts.free;
    end;

    //now we increment each ID in each group by the total number of verts before it;
    ResetVertReferences(1, aDetailedOBJ, new_face_count);


    Memo4.Lines.add('Finshed creating new vertices and faces.');
    Memo4.Lines.add('Split '+IntToStr(original_face_count)+' faces into '+IntToStr(new_face_count)+' faces.');


//    Memo1.Lines.add('Adding unchanged groups/patches...');
//    for aGroup in anOBJ.children do
//      begin
//        for anotherGroup in anotherOBJ.children do
//          begin
//            if aGroup = anotherGroup then
//              break;
////        if aGroup.ter_def = '0' then
//            anotherOBJ.children.Add(aGroup); //add groups which are not identical, i.e. unchanged from original
//          end;
//      end;
//    Memo1.Lines.add('Finished adding unchanged groups/patches.');

    anOBJ := aDetailedOBJ;   //assign edited OBJ for export
  finally
//    anotherOBJ.free;
//    anotherGroup.free;

    Memo1.Lines.add('Done adding detail!');
  end;



end;

