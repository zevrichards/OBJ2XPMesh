procedure TForm1.Convert2Triangles;
var aPrimitive: TPRIMITIVE;
    aPatch: TPATCH;
    aGroup: TOBJ_Group;
    aVertex: TVERTEX;
    v: integer;
begin
  Memo1.Lines.Add('Starting conversion of primitives to trianglulated Mesh...');
  {Do I need a primitivelist or can i iterate through each patch and its children primitives}

  {For aPrimitive in PrimitiveList do
  begin
    Case aPrimitive.prim_type of
      0:begin
//          Triangles(aPrimitive.id);
        end;
      1:begin
//          TriangleStrip(aPrimitive.id);
        end;
      2:begin
//          TriangleFan(aPrimitive.id);
        end;
      else Memo1.Lines.Add('Incorrect Primitive type. Expected integer 0,1 or 2. Got '+IntToStr(aPrimitive.prim_type))
    End;
  end;
  Memo1.Lines.Add('Done Conversion to Mesh!');}


  For aPatch in aDSF.children do
  begin
    aGroup := TOBJ_Group.create(aPatch);
    anOBJ.children.add(aGroup);
    For aPrimitive in aPatch.children do
    begin
      for aVertex in aPrimitive.children do
        aGroup.Vertices.Add(aVertex);

      v := 0;
      Case aPrimitive.prim_type of
      0:begin  //induvidual

          While v < aPrimitive.children.count do
           begin
            //create faces from groups of 3 and add to face list
            aGroup.Faces.Add(TOBJ_Face.create(aPrimitive.children[v+2].id, aPrimitive.children[v+1].id, aPrimitive.children[v].id, IntToStr(aPatch.ter_def)));
            inc(v,3);
           end;
        end;
      1:begin //triangle fans
          While v < aPrimitive.children.count do
            begin
              If v+2 < aPrimitive.children.Count then //check to make sure that we still have more verts to read
                aGroup.Faces.Add(TOBJ_Face.create(aPrimitive.children[v+2].id, aPrimitive.children[v+1].id, aPrimitive.children[v].id, IntToStr(aPatch.ter_def)));       //first in forward order...
              inc(v,2);
              If v+1 < aPrimitive.children.Count then //check to make sure that we still have more verts to read
                aGroup.Faces.Add(TOBJ_Face.create(aPrimitive.children[v+1].id, aPrimitive.children[v-1].id, aPrimitive.children[v].id, IntToStr(aPatch.ter_def)));           //then in backward order to preserve upward facing polygons
            end;
        end;
      2:begin
//          TriangleFan(aPrimitive.id);
        end;
      else Memo1.Lines.Add('Incorrect Primitive type. Expected integer 0,1 or 2. Got '+IntToStr(aPrimitive.prim_type))
    End;
    end;
  end;
end;

