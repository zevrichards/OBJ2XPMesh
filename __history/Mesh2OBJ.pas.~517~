procedure TForm1.ReadElevations(FileName: string; out rows_out: integer);
var FS: TFileStream;
    r,c: integer;
    d: word;
begin
			

  FS:= TFileStream.Create(FileName, fmopenread + fmShareDenyNone{ or fmShareDenyWrite});
  rows_out := trunc(sqrt(FS.Size/8)*2);  //total_rows=total_columns

  try
    FS.Position:=0;
    SetLength(RAW_Array, rows_out+1, rows_out+1);

    For r := rows_out downto 1 do
    begin
      For c := 1 to rows_out do
      begin
        If FS.Read(d, sizeof(d)) > 0 then
        begin
          RAW_Array[r,c] := d;
        end;
      end;
    end;

  finally
    FS.Free;
  end;
end;

function TForm1.FindElevation(aVertex: TOBJ_Vertex; total_rows: integer): word;
var r,c: integer;
begin
//    Find XY position as fraction of extents
//    Determine row and column position based on fraction of total rows/columns

  //X and Y below may have been incorrectly exchanged
  r := trunc(((Extents[1]-(aVertex.Y))/(Extents[1]-Extents[2]))*total_rows);      //(N - vertex_lat)/(N-S) * total_rows
  c := trunc(((Extents[3]-(aVertex.X))/(Extents[3]-Extents[4]))*total_rows);    //(W - vertex_long)/(W-E) * total_columns

  result := RAW_array[r,c];
end;

procedure TForm1.SetExtents(aPatchVertex: TPATCH_VERTEX);
begin
    //northern most vertex
  If aPatchVertex.lat > Extents[1] then
    Extents[1] := aPatchVertex.lat;
  //southern most vertex
  If aPatchVertex.lat < Extents[2] then
    Extents[2] := aPatchVertex.lat;
  //western most vertex
  If aPatchVertex.long < Extents[3] then
    Extents[3] := aPatchVertex.long;
  //eastern most vertex
  If aPatchVertex.long > Extents[4] then
    Extents[4] := aPatchVertex.long;
end;

end.

